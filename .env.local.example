# ReviewSense V2 — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Sur Vercel : Settings → Environment Variables

# ────────────────────────────────────────────
# ANTHROPIC (Claude AI)
# Obtenir sur : https://console.anthropic.com
# ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ────────────────────────────────────────────
# RAPIDAPI
# Obtenir sur : https://rapidapi.com
# 1. Créer un compte sur rapidapi.com
# 2. S'abonner aux 3 APIs ci-dessous
# 3. Copier la clé X-RapidAPI-Key (une seule clé pour toutes les APIs)
# ────────────────────────────────────────────
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────
# APIs RapidAPI utilisées — à souscrire
# ────────────────────────────────────────────

# 1. AMAZON REVIEWS
#    → https://rapidapi.com/amaru-labs-amaru-labs-default/api/amazon-review-scraping
#    Host: amazon-review-scraping.p.rapidapi.com
#    Plan gratuit : 100 req/mois

# 2. GOOGLE MY BUSINESS REVIEWS (Outscraper)
#    → https://rapidapi.com/outscraper/api/outscraper
#    Host: outscraper.p.rapidapi.com
#    Plan gratuit disponible (crédits inclus)

# 3. TRIPADVISOR REVIEWS
#    → https://rapidapi.com/Chetan11dev/api/tripadvisor-scraper
#    Host: tripadvisor-scraper.p.rapidapi.com
#    Plan gratuit : 100 req/mois
